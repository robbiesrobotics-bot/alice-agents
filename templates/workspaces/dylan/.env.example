# A.L.I.C.E. Stripe Webhook Handler — Environment Variables
# Copy to ~/alice-observability/.env and fill in Rob's values
# Then: source ~/alice-observability/.env  (or restart the service)

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Get from: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...           # Live secret key (swap from sk_test_ for dev)

# Get from: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — get from: Stripe Dashboard → Products → Pro/Cloud → Price → API ID
STRIPE_PRO_PRICE_ID=price_...
STRIPE_CLOUD_PRICE_ID=price_...

# ── Supabase ───────────────────────────────────────────────────────────────────
# URL: https://tfodkdtknoaodavakajg.supabase.co (known)
# Service role key: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_URL=https://tfodkdtknoaodavakajg.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── n8n ────────────────────────────────────────────────────────────────────────
# URL for the n8n welcome email webhook trigger
# Format: http://<ubuntu-desktop-ip>:5678/webhook/stripe-checkout-completed
N8N_WEBHOOK_URL=http://100.106.110.119:5678/webhook/stripe-checkout-completed

# ── Resend (email delivery) ────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Flask Server ───────────────────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5001
