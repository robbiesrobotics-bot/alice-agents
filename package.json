{
  "name": "@robbiesrobotics/alice-agents",
  "version": "1.5.3",
  "description": "A.L.I.C.E. \u2014 31 AI agents for OpenClaw. One conversation, one team.",
  "bin": {
    "alice-agents": "bin/alice-install.mjs",
    "alice-cloud": "bin/alice-cloud.cjs"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "openclaw",
    "ai-agents",
    "multi-agent",
    "orchestration",
    "alice"
  ],
  "license": "MIT",
  "files": [
    "bin/",
    "lib/",
    "tools/",
    "snapshots/",
    "templates/agents-starter.json",
    "templates/agents-pro.json",
    "templates/mission-control-bridge/",
    "templates/skills/",
    "templates/workspaces/",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "test:check": "node --check lib/*.mjs bin/*.mjs",
    "release:check": "node lib/release-guard.mjs",
    "prepublishOnly": "npm test && npm run test:check && npm run release:check"
  },
  "publishConfig": {
    "access": "public"
  }
}