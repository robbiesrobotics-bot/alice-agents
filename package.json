{
  "name": "@robbiesrobotics/alice-agents",
  "version": "1.5.13",
  "description": "A.L.I.C.E. — 36 AI agents for Alice Runtime, OpenClaw, NemoClaw, and Hermes Agent. One conversation, one team.",
  "bin": {
    "alice-agents": "bin/alice-install.mjs"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "openclaw",
    "ai-agents",
    "multi-agent",
    "orchestration",
    "alice"
  ],
  "license": "MIT",
  "files": [
    "bin/",
    "lib/",
    "tools/*.mjs",
    "snapshots/*.json",
    "templates/agents-starter.json",
    "templates/agents-pro.json",
    "templates/workspaces/_shared/*.md",
    "templates/workspaces/athena/*.md",
    "templates/workspaces/devon/*.md",
    "templates/workspaces/dylan/*.md",
    "templates/workspaces/felix/*.md",
    "templates/workspaces/morgan/*.md",
    "templates/workspaces/priya/*.md",
    "templates/workspaces/quinn/*.md",
    "templates/workspaces/sasha/*.md",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "test:check": "node --check lib/*.mjs bin/*.mjs",
    "release:check": "node lib/release-guard.mjs",
    "prepublishOnly": "npm test && npm run test:check && npm run release:check"
  },
  "publishConfig": {
    "access": "public"
  }
}
